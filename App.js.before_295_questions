function TopicDetailScreen({ topic, topicProgress, masteredIds = [], isPro, onBack, onStartExam, onStartChapter, onPaywall }) {
  const questionIds = getTopicQuestionIds(topic);
  const questionCount = questionIds.length;
  const progress = topicProgress?.[topic.id];
  const passRate = progress?.percentage || 0;
  const incorrectCount = progress?.missedIds?.length || 0;
  const isCompleted = progress?.completed || false;
  const masteredSet = new Set(masteredIds);

  // Access gate: for the free topic anyone can practice; for all others you need Pro.
  const isLocked = !topic.isFree && !isPro;
  // Auto-show the paywall after a short browse window so the user can see all the
  // chapters they're about to unlock, then gets hit with the offer once desire is built.
  const autoPaywallShownRef = useRef(false);
  useEffect(() => {
    if (!isLocked) return;
    if (autoPaywallShownRef.current) return;
    const timer = setTimeout(() => {
      autoPaywallShownRef.current = true;
      onPaywall();
    }, 3500);
    return () => clearTimeout(timer);
  }, [isLocked, onPaywall]);

  const handleStartExam = () => {
    if (isLocked) {
      onPaywall();
      return;
    }
    onStartExam && onStartExam();
  };
  const handleStartChapter = (chapter) => {
    if (isLocked) {
      onPaywall();
      return;
    }
    onStartChapter && onStartChapter(chapter);
  };
  
  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.headerSafeArea} edges={['top']}>
