// ========== QUIZ SCREEN ==========
function QuizScreen({ questions, title, onFinish, onBack }) {
  const [currentIndex, setCurrentIndex] = useState(0);
  const [selectedAnswer, setSelectedAnswer] = useState(null);
  const [answered, setAnswered] = useState(false);
  const [correctCount, setCorrectCount] = useState(0);
  const [missedList, setMissedList] = useState([]);
  const [correctList, setCorrectList] = useState([]);

  const current = questions[currentIndex];
  const isLast = currentIndex === questions.length - 1;
  const progress = (currentIndex + 1) / questions.length;

  const handleAnswer = (index) => {
    if (answered) return;
    setSelectedAnswer(index);
    setAnswered(true);
    if (index === current.a) {
      setCorrectCount(c => c + 1);
      setCorrectList(c => [...c, current.id]);
    } else {
      setMissedList(m => [...m, current.id]);
    }
  };

  const handleNext = () => {
    if (isLast) {
      onFinish(correctCount, questions.length, missedList, correctList);
      return;
    }
    setCurrentIndex(i => i + 1);
    setSelectedAnswer(null);
    setAnswered(false);
  };

  const handleFinish = () => {
    onFinish(correctCount, questions.length, missedList, correctList);
  };

  // Save partial progress when the user backs out mid-quiz so mastered/missed state
  // stays in sync (e.g. getting a "missed" question right should remove it even if
  // you don't finish the whole session).
  const handleBack = () => {
    const answeredSoFar = correctList.length + missedList.length;
    if (answeredSoFar > 0) {
      onFinish(correctCount, answeredSoFar, missedList, correctList);
      return;
    }
    onBack();
  };

  const getOptionStyle = (index) => {
    if (!answered) return styles.quizOption;
    if (index === current.a) return [styles.quizOption, styles.quizOptionCorrect];
    if (index === selectedAnswer && index !== current.a) return [styles.quizOption, styles.quizOptionWrong];
    return styles.quizOption;
  };

  const getOptionTextStyle = (index) => {
    if (!answered) return styles.quizOptionText;
    if (index === current.a) return [styles.quizOptionText, { color: COLORS.white }];
    if (index === selectedAnswer && index !== current.a) return [styles.quizOptionText, { color: COLORS.white }];
    return styles.quizOptionText;
  };

  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.headerSafeArea} edges={['top']}>
        <View style={styles.quizHeader}>
          <TouchableOpacity onPress={handleBack} style={styles.quizBackBtn}>
            <Ionicons name="chevron-back" size={28} color={COLORS.white} />
          </TouchableOpacity>
          <Text style={styles.quizHeaderTitle}>{title}</Text>
          <Ionicons name="bookmark-outline" size={24} color={COLORS.white} />
        </View>
        <View style={styles.quizProgressBar}>
          <View style={[styles.quizProgressFill, { width: `${progress * 100}%` }]} />
        </View>
      </SafeAreaView>

      <ScrollView style={styles.quizContent} contentContainerStyle={{ paddingBottom: 40 }}>
        <Text style={styles.quizCounter}>Question {currentIndex + 1} of {questions.length}</Text>
        <Text style={styles.quizQuestionText}>{current.q}</Text>

        {current.o.map((option, idx) => (
          <TouchableOpacity
            key={idx}
            style={getOptionStyle(idx)}
            onPress={() => handleAnswer(idx)}
            activeOpacity={answered ? 1 : 0.7}
          >
            <Text style={getOptionTextStyle(idx)}>{option}</Text>
          </TouchableOpacity>
        ))}
      </ScrollView>

      {answered && (
        <View style={styles.quizBottomBar}>
          <TouchableOpacity style={styles.backToStudyBtn} onPress={isLast ? handleFinish : handleNext}>
            <Text style={styles.backToStudyText}>{isLast ? 'Back to studying' : 'Next question'}</Text>
          </TouchableOpacity>
        </View>
      )}
    </View>
  );
}

