// ========== PURE RN PROGRESS COMPONENTS (no SVG) ==========

// Clean minimal progress circle - Apple Health style
function ProgressCircle({ percent, size = 84 }) {
  const p = Math.min(Math.max(percent, 0), 100);
  return (
    <View style={{ 
      width: size, 
      height: size, 
      borderRadius: size / 2, 
      backgroundColor: 'rgba(255,255,255,0.15)',
      justifyContent: 'center', 
      alignItems: 'center',
      borderWidth: 3,
      borderColor: p > 0 ? '#FACC15' : 'rgba(255,255,255,0.25)',
    }}>
      <Text style={{ fontSize: 22, fontFamily: 'Inter_700Bold', color: '#FFFFFF' }}>{p}%</Text>
    </View>
  );
}

// Semi-circle gauge arcs using per-side border coloring
function GaugeArcs({ outerPct, middlePct, innerPct }) {
  const renderArc = (arcWidth, arcHeight, dimColor, brightColor, pct) => {
    const borderW = 22;
    // 3 visible sides: left (0-33%), top (33-66%), right (66-100%)
    return (
      <View style={{
        position: 'absolute', bottom: 0, width: arcWidth, height: arcHeight, alignSelf: 'center',
        borderTopLeftRadius: arcWidth / 2, borderTopRightRadius: arcWidth / 2,
        borderWidth: borderW, borderBottomWidth: 0,
        borderLeftColor: pct > 0 ? brightColor : dimColor,
        borderTopColor: pct > 33 ? brightColor : dimColor,
        borderRightColor: pct > 66 ? brightColor : dimColor,
      }} />
    );
  };

  return (
    <View style={{ width: 240, height: 130, alignItems: 'center', justifyContent: 'flex-end' }}>
      {renderArc(240, 120, 'rgba(59,76,202,0.2)', 'rgba(59,76,202,0.85)', outerPct)}
      {renderArc(192, 96, 'rgba(250,204,21,0.2)', 'rgba(250,204,21,0.85)', middlePct)}
      {renderArc(144, 72, 'rgba(239,68,68,0.2)', 'rgba(239,68,68,0.85)', innerPct)}
    </View>
  );
}

