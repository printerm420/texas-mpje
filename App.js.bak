  { id: 96, q: "A certificate reads: Subscribed & Sworn to before me on August 5, 2007 by ________. Whose name goes on the blank?", o: ["Notary", "Signer", "Credible Witness", "Secretary of State"], a: 1 },
  { id: 107, q: "Notary certificate must be:", o: ["Blank", "Accurate", "Optional", "Incomplete"], a: 1 },
  { id: 116, q: "A notary must sign:", o: ["Later", "At time of notarization", "At home", "Optional"], a: 1 },
  { id: 117, q: "Notary must date certificate:", o: ["Incorrectly", "Accurately", "Later", "Optional"], a: 1 },
  { id: 133, q: "It is never acceptable to affix a notary seal and signature to a document without:", o: ["The notarial wording", "Being paid", "Giving an oath", "Seeing the person sign the document"], a: 0 },
  { id: 145, q: "Notary must date:", o: ["Incorrectly", "Accurately", "Later", "Optional"], a: 1 },
  { id: 166, q: "Notary must sign:", o: ["Later", "At time of act", "At home", "Optional"], a: 1 },
  { id: 167, q: "Notary must date certificate:", o: ["Incorrectly", "Accurately", "Later", "Optional"], a: 1 },
  { id: 181, q: "Notary certificates are signed by:", o: ["Notary", "Secretary of State", "Client", "Lender"], a: 0 },
  { id: 195, q: "Notary must date:", o: ["Incorrectly", "Accurately", "Later", "Optional"], a: 1 },
  { id: 240, q: "A notary must include their \"Commission Expiration Date\" on:", o: ["Every notarial certificate", "Only on affidavits", "Only when using a seal", "Only for real estate documents"], a: 0 },
  { id: 263, q: "When the venue of the Notary's certificate has been filled in beforehand with an incorrect state and county, the Notary must:", o: ["Attach a loose certificate with a correct venue", "Reject the document", "Not tamper with words that may have been filled in by an attorney", "Line through the inapplicable words, writing in the correct state and county"], a: 3 },
  { id: 277, q: "A notary public must include their \"Commission Expiration Date\" on:", o: ["Every notarial certificate", "Only on affidavits", "Only when using a seal", "Only for real estate documents"], a: 0 },
  { id: 279, q: "It is never acceptable to affix a notary seal and signature to a document without:", o: ["The notarial wording", "Being paid", "Giving an oath", "Seeing the person sign the document"], a: 0 },
];

export default function App() {
  const [currentScreen, setCurrentScreen] = useState('study');
  const [masteryScore, setMasteryScore] = useState(0);
  const [dailyStreak, setDailyStreak] = useState(0);
  const [longestStreak, setLongestStreak] = useState(0);
  const [totalTests, setTotalTests] = useState(0);
  const [correctAnswers, setCorrectAnswers] = useState(0);
  const [answeredQuestions, setAnsweredQuestions] = useState(0);
  const [studiedDays, setStudiedDays] = useState([]);
  const [freeTestUsed, setFreeTestUsed] = useState(false);
  const [lastFreeTestResults, setLastFreeTestResults] = useState(null);
  const [todayQuestionTimestamp, setTodayQuestionTimestamp] = useState(null);
  const [missedIds, setMissedIds] = useState([]);
  const [quizQuestions, setQuizQuestions] = useState([]);
  const [quizTitle, setQuizTitle] = useState('');
  const [quizResults, setQuizResults] = useState(null);
  const [isPro, setIsPro] = useState(false);
  const [selectedTopic, setSelectedTopic] = useState(null);
  const [topicProgress, setTopicProgress] = useState({});

  let [fontsLoaded] = useFonts({ Inter_400Regular, Inter_500Medium, Inter_600SemiBold, Inter_700Bold });

  // Initialize RevenueCat and check entitlement
  useEffect(() => {
    const initRevenueCat = async () => {
      try {
        Purchases.setLogLevel(LOG_LEVEL.DEBUG);
        await Purchases.configure({ apiKey: REVENUECAT_API_KEY });
        console.log('[RevenueCat] Initialized successfully');
        
        // Add listener for customer info updates (fires on purchase)
        Purchases.addCustomerInfoUpdateListener((info) => {
          console.log('[RevenueCat] Customer info updated');
          console.log('[RevenueCat] Active entitlements:', Object.keys(info.entitlements.active));
          const isActive = info.entitlements.active[ENTITLEMENT_ID] !== undefined;
          console.log('[RevenueCat] isPro after update:', isActive);
          setIsPro(isActive);
        });
        
        await checkEntitlement();
      } catch (e) {
        console.log('[RevenueCat] Init error:', e);
      }
    };
    initRevenueCat();
    loadUserData();
  }, []);

  const checkEntitlement = async (showDebugAlert = false) => {
    try {
      const customerInfo = await Purchases.getCustomerInfo();
      const activeEntitlements = Object.keys(customerInfo.entitlements.active);
      console.log('[RevenueCat] All entitlements:', JSON.stringify(customerInfo.entitlements, null, 2));
      console.log('[RevenueCat] Active entitlements:', activeEntitlements);
      const isActive = customerInfo.entitlements.active[ENTITLEMENT_ID] !== undefined;
      setIsPro(isActive);
      console.log('[RevenueCat] Entitlement check - looking for:', ENTITLEMENT_ID);
      console.log('[RevenueCat] Entitlement check result:', isActive ? 'PRO' : 'FREE');
      
      if (showDebugAlert) {
        Alert.alert(
          'Entitlement Debug',
          `Looking for: "${ENTITLEMENT_ID}"\n\nActive entitlements: ${activeEntitlements.length > 0 ? activeEntitlements.join(', ') : 'NONE'}\n\nisPro: ${isActive}`
        );
      }
      
      return isActive;
    } catch (e) {
      console.log('[RevenueCat] Entitlement check error:', e);
      if (showDebugAlert) {
        Alert.alert('Error', `Entitlement check failed: ${e.message}`);
      }
      return false;
    }
  };

  const showPaywall = async () => {
    try {
      // Always show the paywall (not "IfNeeded") so user can purchase
      const paywallResult = await RevenueCatUI.presentPaywall();
      console.log('[RevenueCat] Paywall result:', paywallResult);
      
      // Check entitlement after paywall closes
      const nowPro = await checkEntitlement();
      console.log('[RevenueCat] After paywall close, isPro:', nowPro);
      if (nowPro) {
        Alert.alert('Welcome!', 'You now have full access to all questions and features!');
      }
    } catch (e) {
      console.log('[RevenueCat] Paywall error:', e);
    }
  };

  const loadUserData = async () => {
    try {
      const data = await AsyncStorage.getItem('@user_progress');
      if (data) {
        const p = JSON.parse(data);
        setMasteryScore(p.masteryScore || 0);
        setDailyStreak(p.dailyStreak || 0);
        setLongestStreak(p.longestStreak || 0);
        setTotalTests(p.totalTests || 0);
        setCorrectAnswers(p.correctAnswers || 0);
        setAnsweredQuestions(p.answeredQuestions || 0);
        setStudiedDays(p.studiedDays || []);
        setFreeTestUsed(p.freeTestUsed || false);
        if (p.lastFreeTestCorrect != null && p.lastFreeTestTotal != null) {
          setLastFreeTestResults({ correct: p.lastFreeTestCorrect, total: p.lastFreeTestTotal });
        }
        setTodayQuestionTimestamp(p.todayQuestionTimestamp || null);
        setMissedIds(p.missedIds || []);
        setTopicProgress(p.topicProgress || {});
      }
    } catch (e) { console.log('Load error:', e); }
  };

  const saveData = async (updates) => {
    try {
      const raw = await AsyncStorage.getItem('@user_progress');
      const current = raw ? JSON.parse(raw) : {};
      const merged = { ...current, ...updates };
      await AsyncStorage.setItem('@user_progress', JSON.stringify(merged));
    } catch (e) { console.log('Save error:', e); }
  };

  const markStudied = async () => {
    const today = getToday();
    const newDays = studiedDays.includes(today) ? studiedDays : [...studiedDays, today];
    const streak = calcStreak(newDays);
    const longest = Math.max(longestStreak, streak);
    setStudiedDays(newDays);
    setDailyStreak(streak);
    setLongestStreak(longest);
    await saveData({ studiedDays: newDays, dailyStreak: streak, longestStreak: longest });
  };

  const startTodayQuestion = async () => {
    // Check if 24 hours have passed since last answer
    if (todayQuestionTimestamp) {
      const timeSinceAnswer = Date.now() - todayQuestionTimestamp;
      const twentyFourHours = 24 * 60 * 60 * 1000;
      if (timeSinceAnswer < twentyFourHours) {
        const hoursLeft = Math.ceil((twentyFourHours - timeSinceAnswer) / (60 * 60 * 1000));
        Alert.alert('Come Back Later', `Your next free question unlocks in ${hoursLeft} hour${hoursLeft !== 1 ? 's' : ''}. Unlock premium for unlimited access!`, [
          { text: 'OK', style: 'cancel' },
          { text: 'Unlock All', onPress: showPaywall },
        ]);
        return;
      }
    }
    const dayOfYear = Math.floor((new Date() - new Date(new Date().getFullYear(), 0, 0)) / 86400000);
    const qIndex = dayOfYear % QUESTIONS.length;
    setQuizQuestions([QUESTIONS[qIndex]]);
    setQuizTitle("Today's");
    setCurrentScreen('quiz');
  };

  const startFreeTest = async () => {
    // If they already took the free test AND we have their results saved, show results
    if (freeTestUsed && lastFreeTestResults) {
      setQuizResults(lastFreeTestResults);
      setCurrentScreen('results');
      return;
    }
    // Otherwise let them take (or retake) the test - handles stale data migration
    const picked = shuffleArray(QUESTIONS).slice(0, 5);
    setQuizQuestions(picked);
    setQuizTitle('Free Test');
    setCurrentScreen('quiz');
  };

  const startQuickExam = () => {
    const picked = shuffleArray(QUESTIONS).slice(0, 10);
    setQuizQuestions(picked);
    setQuizTitle('Quick Exam');
    setCurrentScreen('quiz');
  };

  const startRandomSetExam = () => {
    // Random 45-question set (like the actual NY notary exam)
    const picked = shuffleArray(QUESTIONS).slice(0, 45);
    setQuizQuestions(picked);
    setQuizTitle('Random Set Exam');
    setCurrentScreen('quiz');
  };

  const startMissedQuestions = () => {
    if (missedIds.length === 0) {
      Alert.alert('No Missed Questions', 'You haven\'t missed any questions yet. Keep practicing!');
      return;
    }
    const missedQuestions = QUESTIONS.filter(q => missedIds.includes(q.id));
    setQuizQuestions(shuffleArray(missedQuestions));
    setQuizTitle('Missed Questions');
    setCurrentScreen('quiz');
  };

  const openTopicDetail = (topic) => {
    setSelectedTopic(topic);
    setCurrentScreen('topicDetail');
  };

  const startTopicExam = (topic) => {
    const questionIds = getTopicQuestionIds(topic);
    const topicQuestions = QUESTIONS.filter(q => questionIds.includes(q.id));
    setQuizQuestions(shuffleArray(topicQuestions));
    setQuizTitle(topic.title);
    setCurrentScreen('quiz');
  };

  const finishQuiz = async (correct, total, missed, answeredCorrectlyIds = []) => {
    await markStudied();
    const newCorrect = correctAnswers + correct;
    const newAnswered = answeredQuestions + total;
    const newTests = totalTests + (total > 1 ? 1 : 0);
    const newMastery = Math.round((newCorrect / QUESTIONS.length) * 100);
    // Add new misses, but remove questions that were answered correctly this time
    const afterRemovingCorrect = missedIds.filter(id => !answeredCorrectlyIds.includes(id));
    const newMissed = [...new Set([...afterRemovingCorrect, ...missed])];
    setCorrectAnswers(newCorrect);
    setAnsweredQuestions(newAnswered);
    setTotalTests(newTests);
    setMasteryScore(newMastery);
    setMissedIds(newMissed);
    const updates = { correctAnswers: newCorrect, answeredQuestions: newAnswered, totalTests: newTests, masteryScore: newMastery, missedIds: newMissed };
    
    // Track topic progress if this was a topic exam
    const matchedTopic = TOPICS.find(t => t.title === quizTitle);
    if (matchedTopic) {
      const newTopicProgress = {
        ...topicProgress,
        [matchedTopic.id]: {
          completed: true,
          correct: correct,
          total: total,
          percentage: Math.round((correct / total) * 100),
          missedIds: missed,
        }
      };
      setTopicProgress(newTopicProgress);
      updates.topicProgress = newTopicProgress;
    }
    
    if (quizTitle === "Today's") {
      const timestamp = Date.now();
      setTodayQuestionTimestamp(timestamp);
      updates.todayQuestionTimestamp = timestamp;
    }
    if (quizTitle === 'Free Test') {
      setFreeTestUsed(true);
      setLastFreeTestResults({ correct, total });
      updates.freeTestUsed = true;
      updates.lastFreeTestCorrect = correct;
      updates.lastFreeTestTotal = total;
    }
    await saveData(updates);
    if (quizTitle === 'Free Test') {
      setQuizResults({ correct, total });
      setCurrentScreen('results');
    } else {
      setCurrentScreen('study');
    }
  };

  const goHome = () => { setCurrentScreen('study'); setQuizResults(null); };

  if (!fontsLoaded) {
    return (<View style={styles.loadingContainer}><Text>Loading...</Text></View>);
  }

  const showTabs = currentScreen === 'study' || currentScreen === 'stats' || currentScreen === 'settings';

  return (
    <SafeAreaProvider>
      <StatusBar barStyle="light-content" backgroundColor={COLORS.primary} translucent={false} />
      <View style={styles.container}>
        {currentScreen === 'study' && (
          <StudyScreen
            masteryScore={masteryScore}
            correctAnswers={correctAnswers}
            dailyStreak={dailyStreak}
            studiedDays={studiedDays}
            missedIds={missedIds}
            isPro={isPro}
            topicProgress={topicProgress}
            todayQuestionTimestamp={todayQuestionTimestamp}
            onTodayQuestion={startTodayQuestion}
            onFreeTest={startFreeTest}
            onQuickExam={() => startQuickExam()}
            onRandomSetExam={() => startRandomSetExam()}
            onMissedQuestions={() => startMissedQuestions()}
            onTopicSelect={openTopicDetail}
            onSettings={() => setCurrentScreen('settings')}
            onPaywall={showPaywall}
            onDebugEntitlement={() => checkEntitlement(true)}
          />
        )}
        {currentScreen === 'stats' && (
          <StatsScreen
            masteryScore={masteryScore}
            totalTests={totalTests}
            correctAnswers={correctAnswers}
            answeredQuestions={answeredQuestions}
            dailyStreak={dailyStreak}
            longestStreak={longestStreak}
            onPaywall={showPaywall}
          />
        )}
        {currentScreen === 'quiz' && (
          <QuizScreen
            questions={quizQuestions}
            title={quizTitle}
            onFinish={finishQuiz}
            onBack={goHome}
          />
        )}
        {currentScreen === 'results' && (
          <ResultsScreen results={quizResults} onHome={goHome} onPaywall={showPaywall} />
        )}
        {currentScreen === 'settings' && (
          <SettingsScreen onBack={() => setCurrentScreen('study')} onPaywall={showPaywall} />
        )}
        {currentScreen === 'topicDetail' && selectedTopic && (
          <TopicDetailScreen
            topic={selectedTopic}
            topicProgress={topicProgress}
            onBack={() => setCurrentScreen('study')}
            onStartExam={() => startTopicExam(selectedTopic)}
            onPaywall={showPaywall}
          />
        )}

        {showTabs && (
          <View style={styles.tabBar}>
            <TouchableOpacity style={styles.tab} onPress={() => setCurrentScreen('study')}>
              <Ionicons name={currentScreen === 'study' || currentScreen === 'settings' ? 'book' : 'book-outline'} size={24} color={currentScreen === 'study' || currentScreen === 'settings' ? COLORS.primary : COLORS.textMuted} />
              <Text style={[styles.tabLabel, (currentScreen === 'study' || currentScreen === 'settings') && styles.tabLabelActive]}>Study</Text>
            </TouchableOpacity>
            <TouchableOpacity style={styles.tab} onPress={() => setCurrentScreen('stats')}>
              <Ionicons name={currentScreen === 'stats' ? 'stats-chart' : 'stats-chart-outline'} size={24} color={currentScreen === 'stats' ? COLORS.primary : COLORS.textMuted} />
              <Text style={[styles.tabLabel, currentScreen === 'stats' && styles.tabLabelActive]}>Stats</Text>
            </TouchableOpacity>
          </View>
        )}
      </View>
    </SafeAreaProvider>
  );
}

// ========== COUNTDOWN TIMER COMPONENT ==========
function CountdownTimer({ answeredTimestamp }) {
  const [timeLeft, setTimeLeft] = useState('');
  const [isExpired, setIsExpired] = useState(false);
  
  useEffect(() => {
    if (!answeredTimestamp) {
      setIsExpired(true);
      return;
    }
    
    const calculateTimeLeft = () => {
      const twentyFourHours = 24 * 60 * 60 * 1000;
      const unlockTime = answeredTimestamp + twentyFourHours;
      const diff = unlockTime - Date.now();
      
      if (diff <= 0) {
        setIsExpired(true);
        return '00:00:00';
      }
      
      const hours = Math.floor(diff / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);
      
      return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    };
    
    setTimeLeft(calculateTimeLeft());
    const timer = setInterval(() => {
      setTimeLeft(calculateTimeLeft());
    }, 1000);
    
    return () => clearInterval(timer);
  }, [answeredTimestamp]);
  
  if (isExpired) return null;
  
  return (
    <View style={styles.countdownPill}>
      <Ionicons name="alarm-outline" size={14} color={COLORS.primary} />
      <Text style={styles.countdownPillText}>{timeLeft}</Text>
    </View>
  );
}

// ========== STUDY SCREEN ==========
function StudyScreen({ masteryScore, correctAnswers, dailyStreak, studiedDays, missedIds, isPro, topicProgress, todayQuestionTimestamp, onTodayQuestion, onFreeTest, onQuickExam, onRandomSetExam, onMissedQuestions, onSettings, onPaywall, onDebugEntitlement, onTopicSelect }) {
  const weekDays = getWeekDays();
  // Conversion-optimized readiness: each correct answer = 1%, cap at 100
  const readinessPercent = Math.min(correctAnswers || 0, 100);
  const missedCount = missedIds?.length || 0;
  
  // Check if 24 hours have passed since answering
  const isOnCooldown = todayQuestionTimestamp && (Date.now() - todayQuestionTimestamp) < (24 * 60 * 60 * 1000);

  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.headerSafeArea} edges={['top']}>
        <View style={styles.header}>
          <View style={styles.headerTop}>
            <Text style={styles.headerTitle}>Study</Text>
            <TouchableOpacity 
              style={styles.settingsBtn} 
              onPress={onSettings}
              // onLongPress={onDebugEntitlement} // Debug: uncomment to check entitlements
            >
              <Ionicons name="options-outline" size={24} color={COLORS.white} />
            </TouchableOpacity>
          </View>

          <Text style={styles.streakText}> {dailyStreak} days streak</Text>

          <View style={styles.calendarRow}>
            {weekDays.map((day) => {
              const wasStudied = studiedDays.includes(day.dateStr);
              return (
                <View key={day.dateStr} style={styles.calendarDay}>
                  <Text style={styles.calendarDayText}>{day.label}</Text>
                  <View style={[styles.calendarDateCircle, day.isToday && styles.calendarDateCircleActive]}>
                    <Text style={[styles.calendarDateText, day.isToday && styles.calendarDateTextActive]}>{day.date}</Text>
                  </View>
                  {wasStudied && <View style={styles.studiedDot} />}
                </View>
              );
            })}
          </View>

          <View style={styles.actionButtons}>
            <TouchableOpacity style={styles.unlockBtn} onPress={onPaywall}>
              <View style={styles.unlockBtnContent}>
                <Text style={styles.unlockBtnText}>Unlock all</Text>
                <View style={styles.unlockIconBadge}>
                  <Ionicons name="lock-open" size={20} color={COLORS.textDark} />
                </View>
              </View>
            </TouchableOpacity>
            <TouchableOpacity style={styles.freeTestBtn} onPress={onFreeTest}>
              <Text style={styles.freeTestBtnText}>Take a free test</Text>
            </TouchableOpacity>
          </View>
        </View>
      </SafeAreaView>

      <ScrollView style={styles.content} showsVerticalScrollIndicator={false}>
        {/* Study by Topic Section */}
        <Text style={[styles.sectionTitle, { marginTop: 20, marginBottom: 12 }]}>All Topics</Text>
        <ScrollView 
          horizontal 
          showsHorizontalScrollIndicator={false} 
          contentContainerStyle={{ paddingRight: 16 }}
          style={{ marginHorizontal: -16, paddingLeft: 16 }}
        >
          {TOPICS.map((topic) => {
            const isLocked = !topic.isFree && !isPro;
            const isCompleted = topicProgress?.[topic.id]?.completed || false;
            const showLockIcon = isLocked && topic.id > 4;
            const isHighlighted = topic.id <= 4;
            const questionIds = getTopicQuestionIds(topic);
            return (
              <TouchableOpacity
                key={topic.id}
                style={[styles.topicCard, isHighlighted && styles.topicCardFree]}
                onPress={() => {
                  if (isLocked) {
                    onPaywall();
                  } else {
                    onTopicSelect(topic);
                  }
                }}
                activeOpacity={0.8}
              >
                <View style={styles.topicCardHeader}>
                  <View style={[styles.topicIconCircle, isHighlighted && styles.topicIconCircleFree]}>
                    <Ionicons name={topic.icon} size={18} color={isHighlighted ? COLORS.primary : COLORS.textMuted} />
                  </View>
                  {isCompleted ? (
                    <View style={styles.topicCheckCircleCompleted}>
                      <Ionicons name="checkmark" size={14} color={COLORS.white} />
                    </View>
                  ) : showLockIcon ? (
                    <Ionicons name="lock-open" size={16} color={COLORS.textMuted} />
                  ) : (
                    <View style={styles.topicCheckCircle}>
                      <View style={styles.topicCheckCircleInner} />
                    </View>
                  )}
                </View>
                <Text style={[styles.topicCardTitle, isHighlighted && styles.topicCardTitleFree]} numberOfLines={2}>
                  {topic.title}
                </Text>
                <Text style={styles.topicCardCount}>{questionIds.length} questions</Text>
              </TouchableOpacity>
            );
          })}
        </ScrollView>

        {/* Unlock All Topics button - commented out for testing
        <TouchableOpacity style={styles.unlockTopicsBtn} onPress={onPaywall}>
          <Ionicons name="lock-open" size={18} color={COLORS.white} />
          <Text style={styles.unlockTopicsBtnText}>Unlock All Topics</Text>
        </TouchableOpacity>
        */}

        <View style={[styles.readinessCard, { marginTop: 24 }]}>
          <View style={styles.readinessLeft}>
            <ProgressCircle percent={readinessPercent} size={84} />
          </View>
          <View style={styles.readinessRight}>
            <Text style={styles.readinessTitle}>Notary: Readiness Score</Text>
            <Text style={styles.readinessSubtitleGold}>{readinessPercent}% complete</Text>
          </View>
        </View>

        <Text style={styles.sectionTitle}> NY Notary Exam Modes</Text>

        <View style={styles.quizGrid}>
          <TouchableOpacity style={[styles.quizCard, styles.quizCardYellow, isOnCooldown && styles.quizCardWithTimer]} onPress={onTodayQuestion}>
            {!isOnCooldown ? (
              <View style={styles.tryMeBadge}>
                <Text style={styles.tryMeText}>TRY ME!</Text>
              </View>
            ) : (
              <View style={styles.completedBadge}>
                <Ionicons name="checkmark-circle" size={14} color={COLORS.green} />
                <Text style={styles.completedText}>DONE</Text>
              </View>
            )}
            {isOnCooldown && (
              <View style={styles.quizCardIconTopRight}>
                <Ionicons name="calendar" size={20} color={COLORS.primary} />
              </View>
            )}
            <Text style={styles.quizCardTitle}>Today's</Text>
            <Text style={styles.quizCardTitle}>question</Text>
            {!isOnCooldown && (
              <View style={styles.quizCardIconContainer}>
                <Ionicons name="calendar" size={28} color={COLORS.primary} />
              </View>
            )}
            {isOnCooldown && <CountdownTimer answeredTimestamp={todayQuestionTimestamp} />}
          </TouchableOpacity>

          <TouchableOpacity style={styles.quizCard} onPress={isPro ? onQuickExam : onPaywall}>
            {!isPro && <View style={styles.starBadge}><Ionicons name="star" size={14} color={COLORS.accent} /></View>}
            <Text style={styles.quizCardSubtitle}>10 questions</Text>
            <Text style={styles.quizCardTitle}>Quick Exam</Text>
            <Text style={styles.quizCardNumber}>10</Text>
          </TouchableOpacity>

          <TouchableOpacity style={styles.quizCard} onPress={isPro ? onRandomSetExam : onPaywall}>
            {!isPro && <View style={styles.starBadge}><Ionicons name="star" size={14} color={COLORS.accent} /></View>}
            <Text style={styles.quizCardTitle}>Random Set</Text>
            <Text style={styles.quizCardTitle}>Exam</Text>
            <View style={styles.quizCardIconContainer}>
              <Ionicons name="shuffle" size={28} color={COLORS.primary} />
            </View>
          </TouchableOpacity>

          <TouchableOpacity style={styles.quizCard} onPress={isPro ? onMissedQuestions : onPaywall}>
            {!isPro && <View style={styles.starBadge}><Ionicons name="star" size={14} color={COLORS.accent} /></View>}
            {missedCount > 0 && (
              <View style={styles.missedCountBadge}>
                <Text style={styles.missedCountText}>{missedCount}</Text>
              </View>
            )}
            <Text style={styles.quizCardTitle}>Missed</Text>
            <Text style={styles.quizCardTitle}>Questions</Text>
            <View style={styles.quizCardIconContainer}>
              <Ionicons name="close" size={28} color="#EF4444" />
            </View>
          </TouchableOpacity>
        </View>

        <TouchableOpacity style={styles.promoCard} onPress={onPaywall}>
          <View style={styles.promoContent}>
            <Text style={styles.promoTitle}>Pass your NY Notary Exam</Text>
            <Text style={styles.promoTitle}>with 100% assurance</Text>
            <View style={styles.promoBtn}>
              <Text style={styles.promoBtnText}>Learn more</Text>
            </View>
          </View>
          <Text style={styles.promoEmoji}>🏆</Text>
        </TouchableOpacity>

        <View style={{ height: 24 }} />
      </ScrollView>
    </View>
  );
}

// ========== QUIZ SCREEN ==========
function QuizScreen({ questions, title, onFinish, onBack }) {
  const [currentIndex, setCurrentIndex] = useState(0);
  const [selectedAnswer, setSelectedAnswer] = useState(null);
  const [answered, setAnswered] = useState(false);
  const [correctCount, setCorrectCount] = useState(0);
  const [missedList, setMissedList] = useState([]);
  const [correctList, setCorrectList] = useState([]);

  const current = questions[currentIndex];
  const isLast = currentIndex === questions.length - 1;
  const progress = (currentIndex + 1) / questions.length;

  const handleAnswer = (index) => {
    if (answered) return;
    setSelectedAnswer(index);
    setAnswered(true);
    if (index === current.a) {
      setCorrectCount(c => c + 1);
      setCorrectList(c => [...c, current.id]);
    } else {
      setMissedList(m => [...m, current.id]);
    }
  };

  const handleNext = () => {
    if (isLast) {
      onFinish(correctCount, questions.length, missedList, correctList);
      return;
    }
    setCurrentIndex(i => i + 1);
    setSelectedAnswer(null);
    setAnswered(false);
  };

  const handleFinish = () => {
    onFinish(correctCount, questions.length, missedList, correctList);
  };

  const getOptionStyle = (index) => {
    if (!answered) return styles.quizOption;
    if (index === current.a) return [styles.quizOption, styles.quizOptionCorrect];
    if (index === selectedAnswer && index !== current.a) return [styles.quizOption, styles.quizOptionWrong];
    return styles.quizOption;
  };

  const getOptionTextStyle = (index) => {
    if (!answered) return styles.quizOptionText;
    if (index === current.a) return [styles.quizOptionText, { color: COLORS.white }];
    if (index === selectedAnswer && index !== current.a) return [styles.quizOptionText, { color: COLORS.white }];
    return styles.quizOptionText;
  };

  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.headerSafeArea} edges={['top']}>
        <View style={styles.quizHeader}>
          <TouchableOpacity onPress={onBack} style={styles.quizBackBtn}>
            <Ionicons name="chevron-back" size={28} color={COLORS.white} />
          </TouchableOpacity>
          <Text style={styles.quizHeaderTitle}>{title}</Text>
          <Ionicons name="bookmark-outline" size={24} color={COLORS.white} />
        </View>
        <View style={styles.quizProgressBar}>
          <View style={[styles.quizProgressFill, { width: `${progress * 100}%` }]} />
        </View>
      </SafeAreaView>

      <ScrollView style={styles.quizContent} contentContainerStyle={{ paddingBottom: 40 }}>
        <Text style={styles.quizCounter}>Question {currentIndex + 1} of {questions.length}</Text>
        <Text style={styles.quizQuestionText}>{current.q}</Text>

        {current.o.map((option, idx) => (
          <TouchableOpacity
            key={idx}
            style={getOptionStyle(idx)}
            onPress={() => handleAnswer(idx)}
            activeOpacity={answered ? 1 : 0.7}
          >
            <Text style={getOptionTextStyle(idx)}>{option}</Text>
          </TouchableOpacity>
        ))}
      </ScrollView>

      {answered && (
        <View style={styles.quizBottomBar}>
          <TouchableOpacity style={styles.backToStudyBtn} onPress={isLast ? handleFinish : handleNext}>
            <Text style={styles.backToStudyText}>{isLast ? 'Back to studying' : 'Next question'}</Text>
          </TouchableOpacity>
        </View>
      )}
    </View>
  );
}

// ========== RESULTS SCREEN ==========
function ResultsScreen({ results, onHome, onPaywall }) {
  if (!results) return null;
  const { correct, total } = results;
  const passed = correct >= Math.ceil(total * 0.7);

  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.headerSafeArea} edges={['top']}>
        <View style={styles.resultsHeader}>
          <Text style={styles.resultsHeaderTitle}>Test Results</Text>
        </View>
      </SafeAreaView>
      <View style={styles.resultsBody}>
        <View style={styles.resultsScoreCircle}>
          <Text style={styles.resultsScoreText}>{correct}/{total}</Text>
        </View>
        <Text style={[styles.resultsVerdict, { color: passed ? COLORS.green : COLORS.red }]}>
          {passed ? '🎉 Passed!' : '📚 Keep Studying'}
        </Text>
        <Text style={styles.resultsSubtext}>
          {passed ? 'Great job! You\'re on the right track.' : 'Don\'t worry, practice makes perfect!'}
        </Text>
        <Text style={styles.resultsPromo}>
          Unlock all {QUESTIONS.length} questions to maximize your exam readiness
        </Text>
        <TouchableOpacity style={styles.resultsUnlockBtn} onPress={onPaywall}>
          <Text style={styles.resultsUnlockText}>Unlock All Questions</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.resultsHomeBtn} onPress={onHome}>
          <Text style={styles.resultsHomeText}>Back to studying</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

// ========== STATS SCREEN ==========
function StatsScreen({ masteryScore, totalTests, correctAnswers, answeredQuestions, dailyStreak, longestStreak, onPaywall }) {
  const passRate = answeredQuestions > 0 ? Math.round((correctAnswers / answeredQuestions) * 100) : 0;
  // Gauge percentages: outer=tests(max 20), middle=correct(max total questions), inner=answered(max total questions)
  const outerPct = Math.min(Math.round((totalTests / 20) * 100), 100);
  const middlePct = Math.min(Math.round((correctAnswers / QUESTIONS.length) * 100), 100);
  const innerPct = Math.min(Math.round((answeredQuestions / QUESTIONS.length) * 100), 100);
  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.statsHeaderSafeArea} edges={['top']}>
        <View style={styles.statsHeader}>
          <Text style={styles.statsHeaderTitle}>Stats</Text>
          <View style={styles.passRateContainer}>
            <View style={styles.passRateRow}>
              <Text style={styles.passRateLabel}>Current pass rate</Text>
              <Text style={styles.passRateValue}>{masteryScore}%</Text>
            </View>
            <View style={styles.progressBarTrack}>
              <View style={[styles.progressBarFill, { width: `${Math.max(masteryScore, 2)}%` }]} />
            </View>
          </View>
        </View>
      </SafeAreaView>

      <ScrollView style={styles.content} showsVerticalScrollIndicator={false}>
        <View style={styles.statsSummary}>
          <View style={styles.statsSummaryItem}>
            <Text style={styles.statsSummaryLabel}>Tests taken</Text>
            <View style={styles.statsDot} />
            <Text style={styles.statsSummaryValue}>{totalTests}</Text>
          </View>
          <View style={styles.statsSummaryItem}>
            <Text style={styles.statsSummaryLabel}>Correct answers</Text>
            <View style={[styles.statsDot, { backgroundColor: COLORS.accent }]} />
            <Text style={styles.statsSummaryValue}>{correctAnswers}</Text>
          </View>
          <View style={styles.statsSummaryItem}>
            <Text style={styles.statsSummaryLabel}>Questions taken</Text>
            <View style={[styles.statsDot, { backgroundColor: '#EF4444' }]} />
            <Text style={styles.statsSummaryValue}>{answeredQuestions}</Text>
          </View>
        </View>

        <View style={styles.gaugeContainer}>
          <GaugeArcs outerPct={outerPct} middlePct={middlePct} innerPct={innerPct} />
          <View style={{ position: 'absolute', bottom: 10, alignItems: 'center' }}>
            <Text style={{ fontSize: 22, fontFamily: 'Inter_700Bold', color: COLORS.textDark }}>{masteryScore}%</Text>
            <Text style={{ fontSize: 11, fontFamily: 'Inter_500Medium', color: COLORS.textMuted }}>readiness</Text>
          </View>
        </View>

        <View style={styles.statsList}>
          <View style={styles.statsRow}>
            <Text style={styles.statsRowLabel}>Tests taken</Text>
            <Text style={styles.statsRowValue}>{totalTests}</Text>
          </View>
          <View style={styles.statsDivider} />
          <View style={styles.statsRow}>
            <Text style={styles.statsRowLabel}>Correct answers</Text>
            <Text style={styles.statsRowValue}>{correctAnswers}</Text>
          </View>
          <View style={styles.statsDivider} />
          <View style={styles.statsRow}>
            <Text style={styles.statsRowLabel}>Answered questions</Text>
            <Text style={styles.statsRowValue}>{answeredQuestions}</Text>
          </View>
          <View style={styles.statsDivider} />
          <View style={styles.statsRow}>
            <Text style={styles.statsRowLabel}>Longest streak</Text>
            <Text style={styles.statsRowValue}>{longestStreak} days</Text>
          </View>
          <View style={styles.statsDivider} />
          <View style={styles.statsRow}>
            <Text style={styles.statsRowLabel}>Learned Exam Sets</Text>
            <Text style={styles.statsRowValue}>0</Text>
          </View>
        </View>

        <TouchableOpacity style={styles.promoCard} onPress={onPaywall}>
          <View style={styles.promoContent}>
            <Text style={styles.promoTitle}>Pass your NY Notary Exam</Text>
            <Text style={styles.promoTitle}>with 100% assurance</Text>
            <View style={styles.promoBtn}>
              <Text style={styles.promoBtnText}>Learn more</Text>
            </View>
          </View>
          <Text style={styles.promoEmoji}>🏆</Text>
        </TouchableOpacity>

        <View style={{ height: 24 }} />
      </ScrollView>
    </View>
  );
}

