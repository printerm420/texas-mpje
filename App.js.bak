// ========== HELPERS ==========
const getDateStr = (d) => d.toISOString().split('T')[0];
const getToday = () => getDateStr(new Date());
const getWeekDays = () => {
  const now = new Date();
  const day = now.getDay();
  const mon = new Date(now);
  mon.setDate(now.getDate() - ((day + 6) % 7));
  const days = [];
  const labels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
  for (let i = 0; i < 7; i++) {
    const d = new Date(mon);
    d.setDate(mon.getDate() + i);
    days.push({ label: labels[i], date: d.getDate(), dateStr: getDateStr(d), isToday: getDateStr(d) === getToday() });
  }
  return days;
};
const calcStreak = (studiedDays) => {
  if (!studiedDays || studiedDays.length === 0) return 0;
  const sorted = [...new Set(studiedDays)].sort().reverse();
  const today = getToday();
  const yesterday = getDateStr(new Date(Date.now() - 86400000));
  if (sorted[0] !== today && sorted[0] !== yesterday) return 0;
  let streak = 1;
  for (let i = 1; i < sorted.length; i++) {
    const prev = new Date(sorted[i - 1]);
    const curr = new Date(sorted[i]);
    const diff = (prev - curr) / 86400000;
    if (diff === 1) streak++;
    else break;
  }
  return streak;
};
const shuffleArray = (arr) => {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1));[a[i], a[j]] = [a[j], a[i]]; }
  return a;
};

// Helper to get all question IDs from a topic (including all chapters)
const getTopicQuestionIds = (topic) => {
  if (!topic.chapters) return [];
  return topic.chapters.flatMap(chapter => chapter.questionIds || []);
};

