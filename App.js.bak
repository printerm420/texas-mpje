  { id: 213, q: "A 'Jurat' is the part of an affidavit where:", o: ["The notary certifies the identity of the signer", "The notary certifies that the document was sworn to before them", "The signer acknowledges their signature", "The notary lists their commission expiration date"], a: 1 },
  { id: 217, q: "An 'Affidavit' is:", o: ["An oral statement made under oath", "A signed written statement made under oath", "A formal declaration of a signature", "A certificate of proof"], a: 1 },
  { id: 218, q: "The signature of the notary public and the venue must be:", o: ["Typed", "Pre-printed", "Handwritten", "Embossed"], a: 2 },
  { id: 226, q: "A notary public who is not an attorney and provides legal advice is guilty of:", o: ["A Class E felony", "A misdemeanor", "A civil violation only", "Contempt of court"], a: 1 },
  { id: 247, q: "A 'Jurat' is that part of an affidavit where the notary certifies that:", o: ["The signer acknowledged their signature freely", "The document was sworn to or affirmed before them on a specific date", "The signer is of sound mind and memory", "The document is a true and accurate copy"], a: 1 },
  { id: 253, q: "An oath is:", o: ["An affirmation", "Never used", "A solemn spoken pledge", "a and c"], a: 3 },
