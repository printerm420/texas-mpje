  { id: 88, q: "Notary may administer:", o: ["Contracts", "Oaths", "Laws", "Advice"], a: 1 },
  { id: 107, q: "An oath to a witness:", o: ["Always refers to God", "Can use phrase 'under penalty of perjury'", "Never refers to a Superior Being", "Has only one recommended question"], a: 1 },
  { id: 140, q: "Notary may administer:", o: ["Contracts", "Oaths", "Laws", "Advice"], a: 1 },
  { id: 183, q: "When taking an oath:", o: ["Signer must raise right hand", "Signer must pay extra fee", "Signer must repeat oath", "Raising right hand is not required"], a: 3 },
