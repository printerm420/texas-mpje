  { id: 24, q: "A notary can certify a copy of a power of attorney according to the:", o: ["Civil Code", "Probate Code", "Bus. & Prof. Code", "Notary Public Code"], a: 1 },
  { id: 56, q: "A certified copy certifies that the reproduction:", o: ["Is accurate", "Is never done", "Can be charged $30", "None of the above"], a: 0 },
  { id: 92, q: "Notaries may not certify a copy of a:", o: ["Journal entry requested by the Secretary of State", "Durable power of attorney for health care document", "Journal entry requested by a member of the public", "Limited power of attorney document"], a: 2 },
  { id: 106, q: "A notary can notarize documents to be filed in another State but:", o: ["Must use New York form", "Can't certify signer holds a particular capacity", "Can't charge any fees", "Only jurats"], a: 1 },
  { id: 111, q: "When performing a signature by mark notarization:", o: ["The signer must make his or her mark in the Notary's journal", "The signer does not have to be identified", "The notary must make the mark in his or her journal", "The notary must sign the person's name near his or her mark on the signature line"], a: 0 },
  { id: 234, q: "A 'Deposition' is:", o: ["A type of acknowledgment", "The testimony of a witness taken out of court under oath", "A formal protest of a check", "A signed affidavit"], a: 1 },
  { id: 236, q: "The fee for taking a deposition is $2.00, plus an additional amount for each 100 words. That amount is:", o: ["$0.10", "$0.25", "$0.50", "$1.00"], a: 1 },
  { id: 238, q: "What is the maximum civil penalty for a notary public who fails to perform their duties faithfully?", o: ["They are liable to the party injured for all damages sustained", "A fixed fine of $500", "Only the loss of their commission", "They cannot be sued if the notarization was done for free"], a: 0 },
  { id: 240, q: "A notary public's seal is:", o: ["Required for every notarial act in New York", "Not required, but the notary must include their name, venue, and commission details in black ink", "Only required for real estate documents", "Only required for documents going out of the state"], a: 1 },
  { id: 242, q: "Which of the following describes \"Satisfactory Evidence\" of identity under New York law?", o: ["A business card with the signer's name", "The oath of a credible witness who is known to the notary", "A credit card with a signature on the back", "A social security card"], a: 1 },
  { id: 258, q: "A Notary Public can notarize a signature on a document that:", o: ["They signed as a principal", "In which they have a direct financial interest", "Is incomplete", "Is in a foreign language"], a: 3 },
  { id: 274, q: "A notary may notarize a document written in a foreign language if:", o: ["They understand it fully", "They don't understand it", "The notarial certificate is proper", "It's translated"], a: 2 },
