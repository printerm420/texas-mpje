// ========== TOPIC DETAIL SCREEN ==========
function TopicDetailScreen({ topic, topicProgress, onBack, onStartExam, onPaywall }) {
  const questionIds = getTopicQuestionIds(topic);
  const questionCount = questionIds.length;
  const progress = topicProgress?.[topic.id];
  const passRate = progress?.percentage || 0;
  const incorrectCount = progress?.missedIds?.length || 0;
  const isCompleted = progress?.completed || false;
  
  return (
    <View style={styles.screen}>
      <SafeAreaView style={styles.headerSafeArea} edges={['top']}>
        <View style={styles.topicDetailHeader}>
          <TouchableOpacity onPress={onBack} style={styles.topicDetailBackBtn}>
            <Ionicons name="chevron-back" size={28} color={COLORS.white} />
          </TouchableOpacity>
          <Text style={styles.topicDetailHeaderTitle}>{topic.title}</Text>
          <View style={{ width: 36 }} />
        </View>
        <View style={styles.topicDetailPassRate}>
          <View style={styles.topicDetailPassRateRow}>
            <Text style={styles.topicDetailPassRateLabel}>Pass rate</Text>
            <Text style={styles.topicDetailPassRateValue}>{passRate}%</Text>
          </View>
          <View style={styles.topicDetailProgressTrack}>
            <View style={[styles.topicDetailProgressFill, { width: `${passRate}%` }]} />
          </View>
        </View>
      </SafeAreaView>

      <ScrollView style={styles.content} showsVerticalScrollIndicator={false}>
        <View style={styles.topicFilterRow}>
          <TouchableOpacity style={styles.topicFilterBtn}>
            <Ionicons name="bookmark" size={16} color={COLORS.primary} />
            <Text style={styles.topicFilterBtnText}>Saved</Text>
          </TouchableOpacity>
          <TouchableOpacity style={styles.topicFilterBtn}>
            <Ionicons name="close" size={16} color={COLORS.red} />
            <Text style={styles.topicFilterBtnText}>Incorrect{incorrectCount > 0 ? ` (${incorrectCount})` : ''}</Text>
          </TouchableOpacity>
        </View>

        <TouchableOpacity style={styles.topicTestCard} onPress={onStartExam} activeOpacity={0.8}>
          <Text style={styles.topicTestCardNumber}>01</Text>
          <View style={styles.topicTestCardContent}>
            <Text style={styles.topicTestCardQuestions}>{questionCount} questions</Text>
            <View style={styles.topicTestCardProgress}>
              <View style={[styles.topicTestCardProgressFill, { width: `${passRate}%` }]} />
            </View>
          </View>
          {isCompleted ? (
            <View style={[styles.topicTestCardArrow, { backgroundColor: COLORS.green }]}>
              <Ionicons name="checkmark" size={20} color={COLORS.white} />
            </View>
          ) : (
            <View style={styles.topicTestCardArrow}>
              <Ionicons name="arrow-forward" size={20} color={COLORS.white} />
            </View>
          )}
        </TouchableOpacity>

        <TouchableOpacity style={styles.topicPromoCard} onPress={onPaywall}>
          <View style={styles.topicPromoContent}>
            <Text style={styles.topicPromoTitle}>Pass your NY Notary exam</Text>
            <Text style={styles.topicPromoTitle}>with 100% assurance</Text>
            <View style={styles.topicPromoBtn}>
              <Text style={styles.topicPromoBtnText}>Learn more</Text>
            </View>
          </View>
          <Text style={styles.topicPromoEmoji}>🏆</Text>
        </TouchableOpacity>

        <View style={{ height: 40 }} />
      </ScrollView>
    </View>
  );
}

