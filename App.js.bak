  { id: 200, q: "Notary verifies:", o: ["Truth", "Identity", "Advice", "Ownership"], a: 1 },
  { id: 213, q: "A 'Jurat' is the part of an affidavit where:", o: ["The notary certifies the identity of the signer", "The notary certifies that the document was sworn to before them", "The signer acknowledges their signature", "The notary lists their commission expiration date"], a: 1 },
  { id: 227, q: "When a notary public takes an acknowledgment, they are certifying that:", o: ["The signer appeared before them and admitted to signing the document", "The content of the document is true", "The signer is of sound mind", "The document is legally binding"], a: 0 },
  { id: 228, q: "What is the fee for changing a notary's name or address on the state's records is:", o: ["$5", "$10", "$20", "$25"], a: 1 },
  { id: 238, q: "When taking an acknowledgment, the notary public must certify that the signer:", o: ["Is telling the truth", "Personally appeared before the notary and was known or identified to be the individual described", "Has a valid bank account", "Is a resident of the county of venue"], a: 1 },
  { id: 266, q: "An 'Acknowledgment' differs from an 'Affidavit' in that an acknowledgment:", o: ["Requires the signer to be under oath", "Does not require the signer to swear to the truth of the document's contents", "Is only used for court documents", "Cannot be performed by a notary who is also an attorney"], a: 1 },
  { id: 267, q: "When notarizing a document containing an acknowledgment, the Notary:", o: ["Must see the document signer sign before them", "May accept a document that has already been signed", "Must administer an oath", "Must take a copy of the acknowledgment"], a: 1 },
  { id: 269, q: "When is an oath involved with an acknowledgment:", o: ["Every time", "When the signer would like to swear that the contents of the document are true", "When the signer utilizes a credible witness as ID", "An oath is never used in an acknowledgment"], a: 2 },
  { id: 276, q: "The key wording of an acknowledgement is:", o: ["Subscribed and sworn to", "I swear the document is true", "Personally appeared", "Protest the payment"], a: 2 },
  
  { id: 11, q: "What is a jurat?", o: ["Signature verification only", "Oath + signature", "Copy certification", "ID check only"], a: 1 },
