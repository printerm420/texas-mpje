  { id: 214, q: "Credible witnesses:", o: ["Are never placed under oath", "Must not have a financial interest in the document", "Must always know the notary", "All of the above"], a: 1 },
  { id: 231, q: "The main purpose of a credible identifying witness is to:", o: ["Substitute for a signer", "Watch the signer sign the document", "Prove that a person signed a document", "Identify a signer"], a: 3 },
  { id: 261, q: "If a credible witness personally knows the signer and the notary:", o: ["Only one witness is needed", "Two witnesses are needed", "Three witnesses are needed", "None of the above"], a: 0 },
  
  // Topic 4: Acknowledgments & Jurats
  { id: 10, q: "What is an acknowledgment?", o: ["Sworn statement", "Verification of signature", "Legal advice", "Copy certification"], a: 1 },
  { id: 38, q: "Acknowledgment requires:", o: ["Oath", "Admission of signature", "Witness", "Copy"], a: 1 },
  { id: 60, q: "An acknowledgment certifies that under penalty of perjury:", o: ["Signer's identity was satisfactorily proven to notary", "The signer admits that they signed the document", "The signer appeared before the notary", "All of the above"], a: 3 },
  { id: 74, q: "A notary certificate proves:", o: ["Truth of document", "Identity and act", "Legal advice", "Ownership"], a: 1 },
  { id: 80, q: "The most frequently completed form is:", o: ["The acknowledgment", "Jurat", "Confidential marriage license", "Protest"], a: 0 },
  { id: 96, q: "A certificate reads: Subscribed & Sworn to before me on August 5, 2007 by ________. Whose name goes on the blank?", o: ["Notary", "Signer", "Credible Witness", "Secretary of State"], a: 1 },
  { id: 120, q: "The main purpose of an acknowledgment is to:", o: ["Authenticate signatures", "Establish mental competence", "Require personal appearance", "Both a and c"], a: 3 },
  { id: 121, q: "When notarizing a document containing an acknowledgment, the Notary:", o: ["Must see the document signer sign before them", "May accept a document that has already been signed", "Must administer an oath", "Must take a copy of the acknowledgment"], a: 1 },
  { id: 124, q: "One main purpose of a Jurat is to:", o: ["Not identify the signer", "Copy certify a form", "Make sure the signer signs in front of the Notary", "Gain evidence to insure truthfulness"], a: 2 },
  { id: 127, q: "A notary certificate proves:", o: ["Legal advice", "Identity and act", "Ownership", "Truth of content"], a: 1 },
